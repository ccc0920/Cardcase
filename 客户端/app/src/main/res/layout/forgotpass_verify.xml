<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="60dp" android:gravity="center_vertical" android:orientation="horizontal" android:layout_marginTop="12dp">
            <ImageButton android:id="@+id/backbutton" android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/icon_btn_bg" android:src="@drawable/ion_chevron_back" android:contentDescription="@string/back_button_desc" android:padding="10dp" />
            <TextView android:id="@+id/back" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:text="Back" android:textColor="#86868B" android:textSize="15sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/VerificationTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Check your&#10;email."
            android:textColor="#1D1D1F"
            android:textSize="40sp"
            android:textStyle="bold"
            android:lineSpacingExtra="2dp"
            android:letterSpacing="-0.02" />

        <TextView
            android:id="@+id/welcome_bac"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Enter the 6-digit code we sent you"
            android:textColor="#86868B"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/verify_box"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="52dp"
            android:background="@drawable/field_bg"
            android:gravity="center"
            android:hint="_ _ _ _ _ _"
            android:inputType="number"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:textColor="#1D1D1F"
            android:textColorHint="#AEAEB2"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.4" />

        <Button
            android:id="@+id/verifybutton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/btn_filled"
            android:elevation="4dp"
            android:text="Verify"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="40dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/countdownTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Resend code in 59s"
                android:textColor="#86868B"
                android:textSize="15sp" />

            <Button
                android:id="@+id/resent_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="#00000000"
                android:enabled="false"
                android:text="Resend code"
                android:textColor="#4F46E5"
                android:textSize="15sp"
                android:textStyle="bold"
                android:contentDescription="@string/log_in_button_desc"
                android:minHeight="0dp" />

        </LinearLayout>

        <RelativeLayout android:id="@+id/head" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <ImageView android:id="@+id/ellipse" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

    </LinearLayout>

</ScrollView>

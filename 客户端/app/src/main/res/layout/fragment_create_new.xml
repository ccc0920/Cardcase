<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F7"
    tools:context=".foreground.CreateNewFragment">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:background="#FFFFFF"
        android:elevation="1dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#6366F1"
            android:textSize="16sp"
            android:paddingRight="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="New Card"
            android:textColor="#1D1D1F"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/btn_primary"
            android:text="Save"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- Live card preview -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginLeft="24dp"
                android:layout_marginRight="24dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/card_gradient_blue"
                android:orientation="vertical"
                android:padding="20dp"
                android:clipToOutline="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/showName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your Name"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/showTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Title"
                            android:textColor="#C7D2FE"
                            android:textSize="13sp"
                            android:maxLines="1"
                            android:ellipsize="end" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/imageView"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/avatar_bg"
                        android:padding="2dp" />

                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/showCompany"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMPANY"
                    android:textColor="#C7D2FE"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/showPhone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Phone"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/showEmail"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Email"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:gravity="end" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="28dp"
                android:layout_marginBottom="8dp"
                android:text="Tap avatar to change photo"
                android:textColor="#86868B"
                android:textSize="12sp" />

            <!-- Name section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="NAME"
                android:textColor="#86868B"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:background="@drawable/card_premium"
                android:elevation="1dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="First Name"
                        android:textColor="#86868B"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/inputFirstName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Required"
                        android:textSize="15sp"
                        android:textColor="#1D1D1F"
                        android:inputType="textPersonName"
                        android:gravity="end" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginLeft="106dp" android:background="#F0F0F5" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="Last Name"
                        android:textColor="#86868B"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/inputSecondName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Optional"
                        android:textSize="15sp"
                        android:textColor="#1D1D1F"
                        android:inputType="textPersonName"
                        android:gravity="end" />
                </LinearLayout>

            </LinearLayout>

            <!-- Institution section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="INSTITUTION"
                android:textColor="#86868B"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:background="@drawable/card_premium"
                android:elevation="1dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="Title"
                        android:textColor="#86868B"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/inputTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="e.g. Software Engineer"
                        android:textSize="15sp"
                        android:textColor="#1D1D1F"
                        android:inputType="textCapWords"
                        android:gravity="end" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginLeft="106dp" android:background="#F0F0F5" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="Company"
                        android:textColor="#86868B"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/inputCompany"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="e.g. Acme Corp"
                        android:textSize="15sp"
                        android:textColor="#1D1D1F"
                        android:inputType="textCapWords"
                        android:gravity="end" />
                </LinearLayout>

            </LinearLayout>

            <!-- Contact section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="CONTACT"
                android:textColor="#86868B"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:background="@drawable/card_premium"
                android:elevation="1dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="Phone"
                        android:textColor="#86868B"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/inputPhone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="+1 555 000 0000"
                        android:textSize="15sp"
                        android:textColor="#1D1D1F"
                        android:inputType="phone"
                        android:gravity="end" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginLeft="106dp" android:background="#F0F0F5" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textColor="#86868B"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/inputEmail"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="you@example.com"
                        android:textSize="15sp"
                        android:textColor="#1D1D1F"
                        android:inputType="textEmailAddress"
                        android:gravity="end" />
                </LinearLayout>

            </LinearLayout>

            <!-- Hidden stubs required by CreateNewFragment code -->
            <TextView android:id="@+id/inputWeb" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/inputStreet" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/inputCity" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/inputState" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/inputPostcode" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>

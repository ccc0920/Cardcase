<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp">

        <!-- Nav bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <ImageButton
                android:id="@+id/backbutton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/icon_btn_bg"
                android:src="@drawable/ion_chevron_back"
                android:contentDescription="@string/back_button_desc"
                android:padding="10dp" />

            <TextView
                android:id="@+id/back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Back"
                android:textColor="#86868B"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Title block -->
        <TextView
            android:id="@+id/loginTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Welcome&#10;back."
            android:textColor="#1D1D1F"
            android:textSize="40sp"
            android:textStyle="bold"
            android:lineSpacingExtra="2dp"
            android:letterSpacing="-0.02" />

        <TextView
            android:id="@+id/welcome_bac"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Sign in to continue to CardCase"
            android:textColor="#86868B"
            android:textSize="16sp" />

        <!-- Email -->
        <TextView
            android:id="@+id/emailadress_string"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="44dp"
            android:text="Email"
            android:textColor="#1D1D1F"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <EditText
            android:id="@+id/email_string"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/field_bg"
            android:hint="you@example.com"
            android:inputType="textEmailAddress"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:textColor="#1D1D1F"
            android:textColorHint="#AEAEB2"
            android:textSize="16sp" />

        <!-- Password -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/login_password"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Password"
                android:textColor="#1D1D1F"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <Button
                android:id="@+id/forgetpassword_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#00000000"
                android:contentDescription="@string/log_in_button_desc"
                android:text="Forgot?"
                android:textColor="#4F46E5"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingLeft="0dp"
                android:paddingRight="0dp"
                android:minHeight="0dp" />

        </LinearLayout>

        <EditText
            android:id="@+id/login_password_string"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/field_bg"
            android:hint="Your password"
            android:inputType="textPassword"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:textColor="#1D1D1F"
            android:textColorHint="#AEAEB2"
            android:textSize="16sp" />

        <!-- CTA -->
        <Button
            android:id="@+id/logInButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/btn_filled"
            android:elevation="4dp"
            android:text="Sign In"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <!-- Footer -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="40dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/signUpLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New to CardCase?"
                android:textColor="#86868B"
                android:textSize="15sp"
                android:contentDescription="@string/already_have_account_desc" />

            <Button
                android:id="@+id/signUpLink_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#00000000"
                android:text="Create account"
                android:textColor="#4F46E5"
                android:textSize="15sp"
                android:textStyle="bold"
                android:contentDescription="@string/log_in_button_desc"
                android:paddingLeft="6dp"
                android:paddingRight="0dp"
                android:minHeight="0dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>

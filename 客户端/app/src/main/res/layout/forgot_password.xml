<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="60dp" android:gravity="center_vertical" android:orientation="horizontal" android:layout_marginTop="12dp">
            <ImageButton android:id="@+id/backbutton" android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/icon_btn_bg" android:src="@drawable/ion_chevron_back" android:contentDescription="@string/back_button_desc" android:padding="10dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="10dp" android:text="Back" android:textColor="#86868B" android:textSize="15sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Reset&#10;Password"
            android:textColor="#1D1D1F"
            android:textSize="40sp"
            android:textStyle="bold"
            android:lineSpacingExtra="2dp"
            android:letterSpacing="-0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Verify your identity with your security question"
            android:textColor="#86868B"
            android:textSize="16sp" />

        <!-- Email -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="44dp" android:text="EMAIL" android:textColor="#1D1D1F" android:textSize="12sp" android:textStyle="bold" android:letterSpacing="0.08" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/email_string"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="@drawable/field_bg"
                android:hint="you@example.com"
                android:inputType="textEmailAddress"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:textColor="#1D1D1F"
                android:textColorHint="#AEAEB2"
                android:textSize="16sp" />

            <Button
                android:id="@+id/loadQuestionButton"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/btn_filled"
                android:text="Look up"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp" />

        </LinearLayout>

        <!-- Security question display (shown after lookup) -->
        <LinearLayout
            android:id="@+id/questionSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="YOUR SECURITY QUESTION"
                android:textColor="#1D1D1F"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/questionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/field_bg"
                android:padding="18dp"
                android:text=""
                android:textColor="#1D1D1F"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="ANSWER"
                android:textColor="#1D1D1F"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <EditText
                android:id="@+id/answerEditText"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/field_bg"
                android:hint="Your answer"
                android:inputType="text"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:textColor="#1D1D1F"
                android:textColorHint="#AEAEB2"
                android:textSize="16sp" />

            <Button
                android:id="@+id/NextButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="36dp"
                android:layout_marginBottom="40dp"
                android:background="@drawable/btn_filled"
                android:elevation="4dp"
                android:text="Verify &amp; Continue"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />

        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="40dp" />

    </LinearLayout>

</ScrollView>

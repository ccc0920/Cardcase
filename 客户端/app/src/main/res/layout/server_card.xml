<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <!-- Front face: colored gradient + Image-#1 layout -->
    <LinearLayout
        android:id="@+id/cardFront"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_gradient_blue"
        android:orientation="vertical"
        android:padding="16dp"
        android:elevation="2dp"
        android:clipToOutline="true">

        <!-- Avatar + Name row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/cardAvatar"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/avatar_bg"
                android:src="@drawable/avatar_default"
                android:scaleType="centerCrop"
                android:clipToOutline="true" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/showName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/showTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="#C7D2FE"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp"
            android:background="#44FFFFFF" />

        <!-- Company row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="7dp">

            <ImageView
                android:id="@+id/iconCompany"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/bank"
                android:tint="#C7D2FE"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/showCompany"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#C7D2FE"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Phone row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="7dp">

            <ImageView
                android:id="@+id/iconPhone"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/phone"
                android:tint="#FFFFFF"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/showPhone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Email row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iconEmail"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/email"
                android:tint="#FFFFFF"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/showEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

    <!-- Back face: white with QR code -->
    <LinearLayout
        android:id="@+id/cardBack"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:minHeight="190dp"
        android:background="@drawable/card_premium"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="invisible"
        android:clipToOutline="true">

        <ImageView
            android:id="@+id/qrView"
            android:layout_width="120dp"
            android:layout_height="120dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tap to flip back"
            android:textColor="#86868B"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Hidden stubs for old code compatibility -->
    <ImageView android:id="@+id/imageView2" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <ImageView android:id="@+id/imageView3" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <ImageView android:id="@+id/imageView4" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

</FrameLayout>

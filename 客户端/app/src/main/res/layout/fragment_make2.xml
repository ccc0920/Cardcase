<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F7"
    tools:context=".foreground.Make2Fragment">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:background="#FFFFFF"
        android:elevation="1dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/backMake2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableLeft="@drawable/ion_chevron_back"
            android:drawablePadding="2dp"
            android:drawableTint="#6366F1"
            android:text="Back"
            android:textColor="#6366F1"
            android:textSize="16sp"
            android:padding="4dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Order Details"
            android:textColor="#1D1D1F"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/nextMake2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next"
            android:textColor="#6366F1"
            android:textSize="16sp"
            android:padding="4dp" />

    </LinearLayout>

    <!-- Step indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:paddingLeft="32dp"
        android:paddingRight="32dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
            <View android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/swatch_selected" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Choose" android:textSize="11sp" android:textColor="#86868B" />
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="1" android:background="#6366F1" android:layout_marginBottom="14dp" />

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
            <View android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/card_gradient_blue" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Details" android:textSize="11sp" android:textColor="#6366F1" android:textStyle="bold" />
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="1" android:background="#E5E5EA" android:layout_marginBottom="14dp" />

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
            <View android:layout_width="28dp" android:layout_height="28dp" android:background="@drawable/avatar_bg" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Review" android:textSize="11sp" android:textColor="#86868B" />
        </LinearLayout>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- Material & Quantity -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="24dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="PRINTING OPTIONS"
                android:textColor="#86868B"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:background="@drawable/card_premium"
                android:elevation="1dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="8dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="Material"
                        android:textColor="#86868B"
                        android:textSize="14sp" />
                    <Spinner
                        android:id="@+id/spinnerMaterial"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:entries="@array/spinner_items"
                        android:background="@null" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginLeft="106dp" android:background="#F0F0F5" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="Quantity"
                        android:textColor="#86868B"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/inputQty"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Min. 50"
                        android:textSize="15sp"
                        android:textColor="#1D1D1F"
                        android:inputType="number"
                        android:gravity="end" />
                </LinearLayout>

            </LinearLayout>

            <!-- Delivery Info -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="DELIVERY INFORMATION"
                android:textColor="#86868B"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:background="@drawable/card_premium"
                android:elevation="1dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="Name"
                        android:textColor="#86868B"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/inputRecipName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Recipient name"
                        android:textSize="15sp"
                        android:textColor="#1D1D1F"
                        android:inputType="textPersonName"
                        android:gravity="end" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginLeft="106dp" android:background="#F0F0F5" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="Phone"
                        android:textColor="#86868B"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/inputRecipPhone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="+86 ..."
                        android:textSize="15sp"
                        android:textColor="#1D1D1F"
                        android:inputType="phone"
                        android:gravity="end" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginLeft="106dp" android:background="#F0F0F5" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="Address"
                        android:textColor="#86868B"
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/inputRecipAddress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Street, City, Province"
                        android:textSize="15sp"
                        android:textColor="#1D1D1F"
                        android:inputType="textPostalAddress"
                        android:gravity="end" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
